{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext", // ← Changé de "commonjs" à "ESNext"
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "baseUrl": ".",
    "outDir": "dist",
    "moduleResolution": "bundler", // ← Important pour Vite
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["node"] // ← Garde cela pour les types Node.js
  },
  "include": ["src/**/*", "vite.*config.ts"]
}
